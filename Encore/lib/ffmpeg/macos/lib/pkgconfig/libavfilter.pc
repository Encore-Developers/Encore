prefix=../ffmpeg-macos
exec_prefix=${prefix}
libdir=../ffmpeg-macos/lib
includedir=../ffmpeg-macos/include

Name: libavfilter
Description: FFmpeg audio/video filtering library
Version: 9.12.100
Requires: 
Requires.private: libswscale >= 7.5.100, libavutil >= 58.29.100
Conflicts:
Libs: -L${libdir}  -lavfilter 
Libs.private: -pthread -lm
Cflags: -I${includedir}
