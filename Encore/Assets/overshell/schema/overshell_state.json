{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/Encore/Assets/overshell/schema/overshell_state.json",
  "title": "Overshell State",
  "type": "object",
  "properties": {
    "provider": {
      "description": "The provider for this state that will fill out entries",
      "enum": ["json", "controllers", "players"]
    },
    "back_action": {
      "$ref": "overshell_action.json"
    }
  },
  "required": ["provider", "back_action"],
  "allOf": [
    {
      "if": {
        "properties": {
          "provider": {
            "const": "json"
          }
        }
      },
      "then": {
        "properties": {
          "entries": {
            "type": "array"
          }
        },
        "required": ["entries"]
      }
    }
  ]
}